// ── Traces: Spring Boot → Alloy (tail-sampling) → Tempo ─────────────

otelcol.receiver.otlp "traces" {
  grpc {
    endpoint = "0.0.0.0:4317"
  }
  http {
    endpoint = "0.0.0.0:4318"
  }
  output {
    traces = [otelcol.processor.tail_sampling.default.input]
  }
}

otelcol.processor.tail_sampling "default" {
  decision_wait = "10s"
  num_traces    = 50000

  policy {
    name = "errors"
    type = "and"
    and {
      and_sub_policy {
        name = "is-error"
        type = "status_code"
        status_code {
          status_codes = ["ERROR"]
        }
      }
      and_sub_policy {
        name = "sample-rate"
        type = "probabilistic"
        probabilistic {
          sampling_percentage = 100
        }
      }
    }
  }

  policy {
    name = "normal"
    type = "probabilistic"
    probabilistic {
      sampling_percentage = 100
    }
  }

  output {
    traces = [otelcol.exporter.otlp.tempo.input]
  }
}

otelcol.exporter.otlp "tempo" {
  client {
    endpoint = "tempo:4317"
    tls {
      insecure = true
    }
  }
}

// ── Metrics: Spring Boot Actuator → Mimir ────────────────────────────
prometheus.scrape "spring_services" {
  targets = [
    {"__address__" = "host.docker.internal:1010", "__metrics_path__" = "/actuator/prometheus"},
    {"__address__" = "host.docker.internal:1020", "__metrics_path__" = "/actuator/prometheus"},
    {"__address__" = "host.docker.internal:1030", "__metrics_path__" = "/actuator/prometheus"},
  ]
  scrape_interval = "15s"
  forward_to = [prometheus.remote_write.mimir.receiver]
}

prometheus.remote_write "mimir" {
  endpoint {
    url = "http://mimir:9009/api/v1/push"
  }
}
