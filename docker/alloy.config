// Spring Boot Actuator 메트릭 수집 → Mimir 전송
prometheus.scrape "spring_services" {
  targets = [
    {"__address__" = "host.docker.internal:1010", "__metrics_path__" = "/actuator/prometheus"},
    {"__address__" = "host.docker.internal:1020", "__metrics_path__" = "/actuator/prometheus"},
    {"__address__" = "host.docker.internal:1030", "__metrics_path__" = "/actuator/prometheus"},
  ]
  scrape_interval = "15s"
  forward_to = [prometheus.remote_write.mimir.receiver]
}

prometheus.remote_write "mimir" {
  endpoint {
    url = "http://mimir:9009/api/v1/push"
  }
}
